# Скопируй в .env и заполни. На Vercel: Settings → Environment Variables.

# Публичный URL (https://…) для canonical и Open Graph. На Vercel чаще не нужен — есть VERCEL_URL.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Обязательно: Neon «Pooled connection» для serverless
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Секрет для POST /api/setup (Authorization: Bearer …). В production без этого setup недоступен.
SETUP_SECRET=

# Соль для SHA-256 паролей (задайте свой длинный секрет в production)
PASSWORD_SALT=

# Регистрация партнёров с сайта: в production только при значении true
# ALLOW_PUBLIC_REGISTRATION=true

# Telegram-уведомления о новых заявках (не коммитьте реальные значения)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Если "Заявка" — это именно тема (forum topic), укажите её ID (обычно число > 0)
# TELEGRAM_THREAD_ID=
