# Скопируй в .env и заполни. На Vercel: Settings → Environment Variables.

# Публичный URL (https://…) для canonical и Open Graph. На Vercel чаще не нужен — есть VERCEL_URL.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Обязательно: Neon «Pooled connection» для serverless
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Внешний калькулятор смет (construction-xi-kohl → POST /api/smeta): Bearer-секрет и id админа в users
# SMETA_INGEST_SECRET=
# SMETA_INGEST_USER_ID=1
# Разрешённые Origin для CORS (через запятую). По умолчанию slk-finance и construction-xi-kohl.
# SMETA_CORS_ORIGINS=https://construction-xi-kohl.vercel.app,https://slk-finance.vercel.app

# Секрет для POST /api/setup (Authorization: Bearer …). В production без этого setup недоступен.
SETUP_SECRET=

# Соль для SHA-256 паролей (задайте свой длинный секрет в production)
PASSWORD_SALT=

# Регистрация партнёров с сайта: в production только при значении true
# ALLOW_PUBLIC_REGISTRATION=true

# Telegram-уведомления о новых заявках (не коммитьте реальные значения)
TELEGRAM_BOT_TOKEN=
# Группа/канал: часто -100… Если публичный @username — кнопка Telegram в кабинете откроет t.me/тот_же_чат
TELEGRAM_CHAT_ID=
# Если chat_id только числовой — ссылка для партнёров: приглашение или t.me/канал
# NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/+xxxx
# Если "Заявка" — это именно тема (forum topic), укажите её ID (обычно число > 0)
# TELEGRAM_THREAD_ID=

# Тема "порт" (forum topic) для уведомлений о регистрации партнёров
TELEGRAM_PORT_THREAD_ID=59
